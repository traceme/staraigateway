# Database connection (required)
# Docker Compose sets this automatically; override for external databases
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/llmtokenhub

# Redis connection (optional — enables response caching)
# Docker Compose sets this automatically; remove to disable caching
REDIS_URL=redis://localhost:6379

# Encryption key for provider API keys (required)
# Must be exactly 64 hex characters (32 bytes) for AES-256-GCM
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# LiteLLM proxy (optional — if running LiteLLM separately)
LITELLM_API_URL=http://localhost:4000
# Generate with: openssl rand -hex 32
LITELLM_MASTER_KEY=

# Public URL of your instance (used for OAuth callbacks and email links)
# Must match the URL users access in their browser
APP_URL=http://localhost:3000

# Cron job authentication secret (required for /api/cron/* endpoints)
# Generate with: openssl rand -hex 32
CRON_SECRET=

# DB connection pool (optional — sensible defaults provided)
# DB_POOL_MAX=20
# DB_IDLE_TIMEOUT=30
# DB_CONNECT_TIMEOUT=10

# SMTP configuration (optional — enables invitation emails and budget alerts)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@llmtokenhub.com

# Google OAuth (optional — enables "Sign in with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional — enables "Sign in with GitHub")
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
