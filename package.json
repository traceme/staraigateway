{
  "name": "staraigateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:integration": "vitest run --include 'src/lib/server/__integration__/**/*.test.ts' --no-coverage",
    "test:e2e": "vitest run --include 'src/__e2e__/**/*.test.ts' --no-coverage",
    "test:load": "npx tsx scripts/load-test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "arctic": "^3.7.0",
    "chart.js": "^4.5.1",
    "drizzle-orm": "^0.38.0",
    "ioredis": "^5.10.0",
    "nodemailer": "^6.9.0",
    "postgres": "^3.4.0",
    "svelte": "^5.0.0",
    "svelte-i18n": "^4.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.0.0",
    "@types/autocannon": "^7.12.7",
    "@types/nodemailer": "^6.4.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autocannon": "^8.0.0",
    "drizzle-kit": "^0.30.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
